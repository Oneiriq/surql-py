# ========================================
# OPTIONAL: Direct Reverie Configuration
# See configuration docs for details: `./docs/quickstart.md`
# ========================================

# REVERIE_DB_URL="ws://localhost:8080/rpc"              # Full URL with /rpc suffix
# REVERIE_DB_USER="root"                                # Database username
# REVERIE_DB_PASS="root"                                # Database password
# REVERIE_DB_NS="reverie"                               # Database namespace
# REVERIE_DB="dev"                                      # Database name
# REVERIE_DB_TIMEOUT="30.0"                             # Connection timeout in seconds (default: 30.0)
# REVERIE_DB_MAX_CONNECTIONS="10"                       # Maximum connection pool size (default: 10)
# REVERIE_DB_RETRY_MAX_ATTEMPTS="3"                     # Maximum retry attempts (default: 3)
# REVERIE_DB_RETRY_MIN_WAIT="1.0"                       # Minimum retry wait in seconds (default: 1.0)
# REVERIE_DB_RETRY_MAX_WAIT="10.0"                      # Maximum retry wait in seconds (default: 10.0)
# REVERIE_DB_RETRY_MULTIPLIER="2.0"                     # Retry backoff multiplier (default: 2.0)
# REVERIE_MIGRATIONS_DIR="path\to\migrations"           # Directory for Reverie migrations